            "tr_TR",
            "ms_MY",
            "en_PH",
            "en_SG",
            "th_TH",
            "vn_VN",
            "id_ID",
            "zh_MY",
            "zh_CN",
            "zh_TW"
          ]
        }
      }
    }
  },
  "tags": [
    {
      "name": "Champion Data",
      "description": "Endpoints related to champion information and images"
    },
    {
      "name": "Item Data",
